#!/bin/bash
# gen-keybinds — regenerate keybindings.txt from the annotated keys[] table.
# Usage: gen-keybinds <config.h|config.def.h>  (writes to stdout)
# Reads /* === NAME === */ sections, trailing /* desc */ comments on binding
# lines, and /* @help key :: desc */ rows for macro-generated bindings.
# Run by the dwm Makefile on every build; do not edit keybindings.txt by hand.

set -u
CONF="${1:?usage: gen-keybinds <config.h>}"
[ -r "$CONF" ] || { echo "gen-keybinds: cannot read $CONF" >&2; exit 1; }

echo "# dwm keybindings (read by ~/.config/suckless/scripts/help)"
echo "# GENERATED by scripts/gen-keybinds from the annotated keys[] table in"
echo "# config.def.h — edit the trailing comments there, not this file."
echo "# Format: key<TAB>description.  Sections marked by  # === NAME ==="
echo "# Pin syntax: prefix description with \"!\" to render at top of its section."
echo "# sxhkd-launched apps live in sxhkd/sxhkdrc; this file is dwm-internal only."

awk '
    # keys[] table only — ignore rules[]/buttons[] and everything else.
    /static const Key keys\[\] = \{/ { inkeys = 1; next }
    inkeys && /^\};/                 { inkeys = 0 }
    !inkeys                          { next }

    # Section marker: /* === NAME === */
    /^[[:space:]]*\/\*[[:space:]]*===[[:space:]]+.+[[:space:]]+===[[:space:]]*\*\/[[:space:]]*$/ {
        s = $0
        sub(/^[[:space:]]*\/\*[[:space:]]*===[[:space:]]+/, "", s)
        sub(/[[:space:]]+===[[:space:]]*\*\/[[:space:]]*$/, "", s)
        printf "\n# === %s ===\n", s
        next
    }

    # Hand-written row for macro bindings: /* @help key :: desc */
    /^[[:space:]]*\/\*[[:space:]]*@help[[:space:]]/ {
        s = $0
        sub(/^[[:space:]]*\/\*[[:space:]]*@help[[:space:]]+/, "", s)
        sub(/[[:space:]]*\*\/[[:space:]]*$/, "", s)
        i = index(s, " :: ")
        if (i > 0) printf "%s\t%s\n", substr(s, 1, i - 1), substr(s, i + 4)
        next
    }

    # Binding line with trailing description comment.
    /^[[:space:]]*\{/ && /\*\/[[:space:]]*$/ {
        line = $0

        # Description: last /* ... */ on the line.
        desc = line
        sub(/.*\/\*[[:space:]]*/, "", desc)
        sub(/[[:space:]]*\*\/[[:space:]]*$/, "", desc)

        # Modifiers: first field inside the braces, split on |.
        mods = line
        sub(/^[[:space:]]*\{[[:space:]]*/, "", mods)
        sub(/,.*/, "", mods)
        n = split(mods, m, /\|/)
        key = ""
        for (j = 1; j <= n; j++) {
            t = m[j]
            gsub(/[[:space:]]/, "", t)
            if      (t == "MODKEY")      t = "Super"
            else if (t == "ALTKEY")      t = "Alt"
            else if (t == "ShiftMask")   t = "Shift"
            else if (t == "ControlMask") t = "Ctrl"
            else if (t == "0")           continue
            key = key (key == "" ? "" : " + ") t
        }

        # Key symbol: the XK_* token.
        if (match(line, /XK_[A-Za-z0-9_]+/)) {
            k = substr(line, RSTART + 3, RLENGTH - 3)
            if      (k == "comma")  k = ","
            else if (k == "period") k = "."
            key = key (key == "" ? "" : " + ") k
            printf "%s\t%s\n", key, desc
        }
        next
    }
' "$CONF"

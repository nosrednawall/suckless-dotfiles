#!/usr/bin/env bash

shutdown="пЂ‘ Shutdown"
reboot="пЂЎ Reboot"
logout="пЉЅ Logout"
suspend="у°’І Suspend"
#hibernate="Hibernate"

# Variable passed to rofi
options="$shutdown\n$reboot\n$logout\n$suspend"

chosen="$(echo -e "$options" | dmenu -p "Power-Menu " )"
case $chosen in
    $shutdown)
	systemctl poweroff
	;;
    $reboot)
    systemctl reboot
	;;
    $logout)
    pkill -KILL -u $USER
	;;
    $suspend)
	systemctl suspend
	;;
    $hibernate)
	systemctl hibernate
	;;
esac

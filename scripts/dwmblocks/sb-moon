#!/usr/bin/env bash

# Carrega funĂ§ĂŁo para aplicar o tema e o tema de cores
source ~/.config/suckless/scripts/dwmblocks/sb-carrega-tema-dwmblocks

# FunĂ§ĂŁo para calcular a diferenĂ§a de dias desde 2001-01-01 atĂ© hoje
position() {

    # Verifica se possui parametro
    if [ $# -eq 0 ]; then
        # Se nao possui pega a data de hoje
        local now=$(date +%s)                    # Data atual em segundos desde 1970-01-01
    else
        # se nao pega a data do parametro
        local now=$(date -d "$1" +%s)  # Converte a data fornecida para segundos desde 1970-01-01
    fi

    local start=$(date -d "2001-01-01" +%s)  # Data de referĂȘncia em segundos
    local diff=$(( (now - start) / 86400 ))  # DiferenĂ§a em dias
    local seconds_diff=$(( (now - start) % 86400 ))
    local fractional=$(awk "BEGIN { print $seconds_diff / 86400 }")

    # CĂĄlculo das lunaĂ§Ă”es
    local lunations=$(awk "BEGIN { print 0.20439731 + ($diff + $fractional) * 0.03386319269 }")

    # Retorna a posiĂ§ĂŁo normalizada (mĂłdulo 1)
    echo $(awk "BEGIN { print $lunations % 1 }")
}

# FunĂ§ĂŁo para determinar a fase lunar com base na posiĂ§ĂŁo
phase() {
    local pos=$1
    local index=$(awk "BEGIN { print int(($pos * 8) + 0.5) % 8 }")

    case $index in
        0) echo "ó°œ€ Lua Nova" ;;
        1) echo "ó°œ§ Lua Crescente" ;;
        2) echo "ó°œĄ 1/4 Minguante" ;;
        3) echo "ó°œš Lua Minguante" ;;
        4) echo "ó°œą Lua Cheia" ;;
        5) echo "ó°œŠ Lua Minguante" ;;
        6) echo "ó°œŁ 4/4 Minguante" ;;
        7) echo "ó°œ„ Lua Minguante" ;;
    esac
}

# FunĂ§ĂŁo para gerar a notificaĂ§ĂŁo com as fases da lua para os prĂłximos 7 dias
generate_notification() {
    local message=""

    for i in {0..6}; do
        local date=$(date -d "+$i days" +%Y-%m-%d)  # Data atual + i dias
        local date_formated=$(date -d "+$i days" +%d/%m/%Y)
        local pos=$(position "$date")  # Calcula a posiĂ§ĂŁo da lua
        local phase_name=$(phase "$pos")  # ObtĂ©m o nome da fase lunar

        # Adiciona a data e a fase lunar Ă  mensagem
        message+="  $date_formated: $phase_name\n"
    done

    # Envia a notificaĂ§ĂŁo
    notify-send "PrĂłximas fases da Lua" "$message"
}


# FunĂ§ĂŁo principal
main() {

    local pos=$(position)
    local phasename=$(phase $pos)
    #local lua_string=$(echo $phasename | awk -v color="^b$COLOR_5^^c$COLOR_BACKGROUND ^" -v d="^d^" -v color2="^c$COLOR_5^" '{print color $1 d color2" " $2 " " $3 " " d}')
    local icon=$(echo $phasename | awk '{print $1}')
    local fase=$(echo $phasename | awk '{print $2}')
    local nome=$(echo $phasename | awk '{print $3}')

    local output=$(aplicar_tema "$icon" "$fase $nome" "$COLOR_2" "$COLOR_10")

    # Apresentacao condicionada
    case "$OPERATION_MODE" in
        "MINIMO")
            echo ""
            ;;
        "MEDIO")
            echo ""
            ;;
        "MOSTRAR_LUA")
            # ForĂ§a o uso do ponto como separador decimal
            LC_NUMERIC=C printf "%s" "$output"
            ;;
    esac
}
# funcoes cliclaveis
case $BUTTON in
	1) generate_notification ;;
	6) setsid -f st -e emacs -nw "$0" ;;
esac

main
